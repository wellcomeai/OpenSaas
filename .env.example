# ===== DATABASE =====
DATABASE_URL=postgresql+asyncpg://opensaas:password@localhost:5432/opensaas_db

# Используются только в docker-compose.prod.yml для контейнера postgres
POSTGRES_DB=opensaas_db
POSTGRES_USER=opensaas
POSTGRES_PASSWORD=password

# ===== REDIS (опционально) =====
# Если не задан — используется PostgreSQL fallback
# Для включения раскомментировать:
# REDIS_URL=redis://localhost:6379

# ===== JWT =====
SECRET_KEY=your-secret-key-minimum-32-characters-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ===== ADMIN (создаётся при первом запуске) =====
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_in_production

# ===== SMTP EMAIL =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=OpenSaaS
SMTP_USE_TLS=true

# ===== РОБОКАССА =====
ROBOKASSA_MERCHANT_LOGIN=your_merchant_login
ROBOKASSA_PASSWORD1=your_password1
ROBOKASSA_PASSWORD2=your_password2
ROBOKASSA_TEST_MODE=true

# === ПЛАНЫ ПОДПИСКИ ===
PLAN_BASIC_NAME=Basic
PLAN_BASIC_PRICE=990
PLAN_BASIC_INTERVAL=month
PLAN_BASIC_FEATURES=До 100 запросов в день,Email поддержка,Базовая аналитика

PLAN_PRO_NAME=Pro
PLAN_PRO_PRICE=2990
PLAN_PRO_INTERVAL=month
PLAN_PRO_FEATURES=Безлимит запросов,Приоритетная поддержка,API доступ,Расширенная аналитика

# ===== STRIPE (заготовка, не активен) =====
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_ENABLED=false

# ===== APP =====
APP_NAME=OpenSaaS
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# ===== БИЗНЕС ЛОГИКА =====
TRIAL_DAYS=3
REFERRAL_COMMISSION_PERCENT=20

# ===== CodeAI: GitHub App =====
# Создаётся на https://github.com/settings/apps → "New GitHub App"
# Permissions нужны: Contents (Read & write), Pull requests (Read & write),
# Metadata (Read). Subscribe to events: push, installation.
GITHUB_APP_ID=
# PEM ключ App (многострочный). Можно либо вставить целиком,
# либо указать путь к файлу .pem
GITHUB_APP_PRIVATE_KEY=
# Случайная строка, должна совпадать с настройкой в GitHub App → Webhook secret
GITHUB_APP_WEBHOOK_SECRET=
# Client ID/Secret из настроек GitHub App (для OAuth user identity)
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Публичная ссылка для установки App юзерами:
# https://github.com/apps/<your-app-slug>/installations/new
GITHUB_APP_INSTALLATION_URL=

# ===== CodeAI: OpenRouter =====
# Единственный системный ключ — пользователи не видят и не задают свой
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Дефолтные модели для новых юзеров (id из https://openrouter.ai/models)
CODEAI_DEFAULT_PLANNING_MODEL=deepseek/deepseek-chat
CODEAI_DEFAULT_EDITING_MODEL=deepseek/deepseek-chat
# Модель для embeddings (1536-мерные)
CODEAI_EMBEDDINGS_MODEL=openai/text-embedding-3-small

# ===== CodeAI: runtime =====
CODEAI_WORKSPACE_DIR=./tmp/repos
CODEAI_MAX_FILE_SIZE_KB=500
CODEAI_CHUNK_SIZE=100
CODEAI_CHUNK_OVERLAP=20

# ===== Broll (B-roll генерация) =====
# Каталог для сгенерированных MP4 (на Render эфемерен — позже R2)
BROLL_OUTPUT_DIR=/app/broll_output
# Таймаут рендера ffmpeg в секундах
BROLL_RENDER_TIMEOUT=90


# ===== LOCAL DOCKER =====
# DATABASE_URL уже переопределён в docker-compose.local.yml
# Менять не нужно
